# ============================================
# CONFIGURATION KODEFAST
# ============================================
# Copiez ce fichier vers .env.local et remplissez les valeurs
# cp .env.example .env.local

# ============================================
# MODE DEMO (optionnel)
# ============================================
# Mettre "true" pour tester l'interface sans configurer Supabase
# Idéal pour explorer le template avant le déploiement
NEXT_PUBLIC_DEMO_MODE=false

# ============================================
# SUPABASE (requis)
# ============================================
# Récupérez ces valeurs dans votre dashboard Supabase :
# Settings > API > Project URL et anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ============================================
# PRODUCTION (Vercel)
# ============================================
# URL de votre site en production (utilisé pour les redirections OAuth)
# Ne pas définir en développement local
# SITE_URL=https://votre-domaine.com

# ============================================
# SUPABASE SERVICE ROLE (pour API réservations)
# ============================================
# Requis pour créer des réservations depuis la page publique /offre
# Dashboard Supabase > Settings > API > service_role key (secret)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ============================================
# SECRETS SUPABASE VAULT (ne pas mettre ici)
# ============================================
# Ces secrets sont configurés dans Supabase Dashboard > Settings > Vault
# NE PAS les mettre dans .env.local, ils sont gérés côté serveur
#
# STRIPE_SECRET_KEY      - Clé secrète Stripe (sk_live_... ou sk_test_...)
# STRIPE_WEBHOOK_SECRET  - Secret du webhook Stripe (whsec_...)
# RESEND_API_KEY         - Clé API Resend pour les emails (re_...)
# OPENROUTER_API_KEY     - Clé OpenRouter pour l'IA (sk-or-...)
# EMAIL_FROM             - Adresse email d'envoi (noreply@votre-domaine.com)
