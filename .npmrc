# Configuration npm pour KodeFast

# Utiliser le lockfile exact pour garantir les versions
package-lock=true

# Sauvegarder les dépendances exactes
save-exact=true

# Pas d'audit automatique (accélère l'installation)
audit=false

# Pas de financement (messages de funding)
fund=false

# Niveau de log
loglevel=error
